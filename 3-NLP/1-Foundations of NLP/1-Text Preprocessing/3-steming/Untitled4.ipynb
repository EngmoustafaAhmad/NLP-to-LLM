   "source": [
    "import nltk\n",
    "from nltk.stem import PorterStemmer\n",
    "\n",
    "stemmer=PorterStemmer()\n",
    "\n",
    "words=[\"maps\",\"maping\",\"goes\",\"internationnal\",\"important\",\"walking\",\"jumping\",\"jump\",\"plays\",\"gone\",\"goed\"]\n",
    "\n",
    "for word in words :\n",
    "    stemming_words=stemmer.stem(word)\n",
    "    print(f\"{word} ==> {stemming_words}\")\n"
   ]
