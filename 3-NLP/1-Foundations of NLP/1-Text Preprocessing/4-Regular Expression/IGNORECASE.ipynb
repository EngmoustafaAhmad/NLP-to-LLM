    "import re\n",
    "\n",
    "text = \"\"\"The gross cost of operating lease vehicles in FY2021 Q1 was $4.85 billion.\n",
    "In previous quarter i.e. FY2020 Q4 it was $3 billion.fy2020 Q3\"\"\"\n",
    "\n",
    "pattern = 'FY\\d{4} Q[1-4]'\n",
    "\n",
    "matches= re.findall(pattern,text,flags = re.IGNORCASE)\n",
    "\n",
    "matches\n"
   ]
